# syntax=docker/dockerfile:1
FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o bin/gratis-api ./api/cmd/api

FROM gcr.io/distroless/static-debian12
COPY --from=builder /app/bin/gratis-api /gratis-api
EXPOSE 8080 9090
ENTRYPOINT ["/gratis-api"]
